<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Screamer</title>
<style>
    html, body {
        margin: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: black;
    }

    #screamer {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: none;
    }
</style>
</head>
<body>

<img id="screamer" src="image.jpg" alt="Screamer">

<audio id="sound" src="son.mp3"></audio>

<script>
window.onload = () => {
    setTimeout(() => {
        document.getElementById("screamer").style.display = "block";
        document.getElementById("sound").play().catch(() => {
            console.log("Lecture audio bloquée par le navigateur.");
        });
    }, 1000);
};
</script>

</body>
</html>
